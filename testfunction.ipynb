    "def Santosh(balance):\n",
    "  if balance > 10000:\n",
    "    return \"Balance is good\"\n",
    "  elif balance > 7000:\n",
    "    return \"Balance is average\"\n",
    "  elif balance > 5000 and balance <=7000:\n",
    "    return \"Balance is below average\"\n",
    "  else:\n",
    "    return \"Balance is very low\"\n",
    "  \n",
    "print(Santosh(7000))\n"
   ]
  }
